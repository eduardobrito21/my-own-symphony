{
  "name": "my-own-symphony",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript reimplementation of openai/symphony, built harness-first with the Claude Agent SDK",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "tsc --build && pnpm -r --workspace-concurrency=1 run --if-present postbuild",
    "clean": "tsc --build --clean && rm -rf packages/*/dist",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "deps:check": "depcruise --config .dependency-cruiser.cjs packages",
    "typecheck": "tsc --build --pretty",
    "symphony": "node --env-file=.env packages/daemon/dist/index.js",
    "dashboard": "pnpm --filter @symphony/dashboard dev",
    "dashboard:build": "pnpm --filter @symphony/dashboard build",
    "docker:build:agent-base": "pnpm --filter @symphony/types --filter @symphony/daemon --filter @symphony/agent-runtime build && docker build -f docker/agent-base.Dockerfile -t symphony/agent-base:1 ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.10",
    "dependency-cruiser": "^16.7.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}

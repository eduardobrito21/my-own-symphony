{
  "name": "@symphony/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Symphony orchestrator daemon",
  "main": "./dist/index.js",
  "bin": {
    "symphony": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./agent/claude": {
      "types": "./dist/agent/claude/agent.d.ts",
      "default": "./dist/agent/claude/agent.js"
    },
    "./agent/linear-skill": {
      "types": "./dist/agent/claude/linear-skill-loader.d.ts",
      "default": "./dist/agent/claude/linear-skill-loader.js"
    },
    "./agent/runner": {
      "types": "./dist/agent/runner.d.ts",
      "default": "./dist/agent/runner.js"
    },
    "./agent/prompt": {
      "types": "./dist/agent/prompt.d.ts",
      "default": "./dist/agent/prompt.js"
    },
    "./tracker/linear": {
      "types": "./dist/tracker/linear/index.d.ts",
      "default": "./dist/tracker/linear/index.js"
    },
    "./config/repo-workflow": {
      "types": "./dist/config/repo-workflow.d.ts",
      "default": "./dist/config/repo-workflow.js"
    },
    "./execution": {
      "types": "./dist/execution/index.d.ts",
      "default": "./dist/execution/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "default": "./dist/observability/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json && pnpm run postbuild",
    "postbuild": "mkdir -p dist/agent/claude && cp src/agent/claude/linear-skill.md dist/agent/claude/linear-skill.md",
    "clean": "tsc --build tsconfig.build.json --clean && rm -rf dist",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx --watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.123",
    "@bufbuild/protobuf": "^1.10.0",
    "@connectrpc/connect": "^1.6.0",
    "@connectrpc/connect-node": "^1.6.0",
    "@namespacelabs/sdk": "^0.3.0",
    "@symphony/types": "workspace:*",
    "chokidar": "^4.0.3",
    "graphql": "^16.13.2",
    "liquidjs": "^10.20.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}

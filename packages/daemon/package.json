{
  "name": "@symphony/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Symphony orchestrator daemon",
  "main": "./dist/index.js",
  "bin": {
    "symphony": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "clean": "tsc --build tsconfig.build.json --clean && rm -rf dist",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx --watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@symphony/types": "workspace:*",
    "liquidjs": "^10.20.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
